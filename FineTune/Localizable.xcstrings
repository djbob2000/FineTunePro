    "Couldn't change sample rate. The device refused.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法更改采样率，设备拒绝了请求。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن تغيير معدل العينة. رفض الجهاز."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "নমুনার হার পরিবর্তন করা যায়নি। ডিভাইস প্রত্যাখ্যান."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No s'ha pogut canviar la freqüència de mostreig. El dispositiu es va negar."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法變更取樣率。設備拒絕了。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije moguće promijeniti brzinu uzorkovanja. Uređaj je odbio."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nelze změnit vzorkovací frekvenci. Zařízení odmítlo."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke ændre sample rate. Enheden nægtede."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan de bemonsteringsfrequentie niet wijzigen. Het apparaat weigerde."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't change sample rate. The device refused."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't change sample rate. The device refused."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't change sample rate. The device refused."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't change sample rate. The device refused."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Näytetaajuutta ei voitu muuttaa. Laite kieltäytyi."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de modifier la fréquence d'échantillonnage. L'appareil a refusé."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de modifier la fréquence d'échantillonnage. L'appareil a refusé."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Abtastrate konnte nicht geändert werden. Das Gerät weigerte sich."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν ήταν δυνατή η αλλαγή του ποσοστού δειγματοληψίας. Η συσκευή αρνήθηκε."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "નમૂના દર બદલી શકાયો નથી. ઉપકરણે ના પાડી."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לא ניתן לשנות את קצב הדגימה. המכשיר סירב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नमूना दर नहीं बदला जा सका. डिवाइस ने मना कर दिया."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem sikerült módosítani a mintavételi sebességet. A készülék visszautasította."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak dapat mengubah laju sampel. Perangkat menolak."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile modificare la frequenza di campionamento. Il dispositivo ha rifiutato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サンプルレートを変更できませんでした。デバイスが拒否しました。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮಾದರಿ ದರವನ್ನು ಬದಲಾಯಿಸಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ. ಸಾಧನ ನಿರಾಕರಿಸಿತು."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "샘플링 속도를 변경할 수 없습니다. 장치가 거부되었습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak dapat menukar kadar sampel. Peranti itu menolak."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
