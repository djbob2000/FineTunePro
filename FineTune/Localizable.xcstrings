          "stringUnit": {
            "state": "translated",
            "value": "匹配 macOS，或鎖定淺色或深色"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uskladite macOS ili zaključajte na Svijetlo ili Tamno"
