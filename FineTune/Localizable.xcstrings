        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχει ενεργή διόρθωση. Αναζητήστε ή επιλέξτε ένα αγαπημένο παρακάτω."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "કોઈ કરેક્શન સક્રિય નથી. નીચે શોધો અથવા મનપસંદ પસંદ કરો."
