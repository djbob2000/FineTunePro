          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekisteröi FineTune esteettömyysluetteloon ja avaa Järjestelmäasetukset."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre FineTune dans la liste Accessibilité et ouvre les paramètres système."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre FineTune dans la liste Accessibilité et ouvre les paramètres système."
          }
        },
        "de-DE": {
