    "Turn on only if the volume slider doesn't work. FineTune remembers this for each device.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在音量滑块不起作用时开启。FineTune 会为每台设备记住此设置。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتشغيل فقط إذا كان شريط تمرير مستوى الصوت لا يعمل. FineTune يتذكر هذا لكل جهاز."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "শুধুমাত্র ভলিউম স্লাইডার কাজ না করলেই চালু করুন। FineTune প্রতিটি ডিভাইসের জন্য এটি মনে রাখে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Enceneu només si el control lliscant de volum no funciona. FineTune ho recorda per a cada dispositiu."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅當音量滑桿不起作用時才開啟。 FineTune 會為每個裝置記住這一點。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uključi samo ako klizač za glasnoću ne radi. FineTune pamti ovo za svaki uređaj."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapněte pouze v případě, že posuvník hlasitosti nefunguje. FineTune si to pamatuje pro každé zařízení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tænd kun, hvis lydstyrkeskyderen ikke virker. FineTune husker dette for hver enhed."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen inschakelen als de volumeschuifregelaar niet werkt. FineTune onthoudt dit voor elk apparaat."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kytke päälle vain, jos äänenvoimakkuuden liukusäädin ei toimi. FineTune muistaa tämän jokaiselle laitteelle."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez-le uniquement si le curseur de volume ne fonctionne pas. FineTune s'en souvient pour chaque appareil."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez-le uniquement si le curseur de volume ne fonctionne pas. FineTune s'en souvient pour chaque appareil."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur einschalten, wenn der Lautstärkeregler nicht funktioniert. FineTune merkt sich dies für jedes Gerät."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ενεργοποιήστε μόνο εάν το ρυθμιστικό έντασης δεν λειτουργεί. Το FineTune το θυμάται αυτό για κάθε συσκευή."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "જો વોલ્યુમ સ્લાઇડર કામ ન કરે તો જ ચાલુ કરો. FineTune દરેક ઉપકરણ માટે આ યાદ રાખે છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפעל רק אם מחוון עוצמת הקול אינו פועל. FineTune זוכר זאת עבור כל מכשיר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल तभी चालू करें जब वॉल्यूम स्लाइडर काम न करे। FineTune इसे प्रत्येक डिवाइस के लिए याद रखता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csak akkor kapcsolja be, ha a hangerő-csúszka nem működik. FineTune ezt minden eszköznél megjegyzi."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan hanya jika penggeser volume tidak berfungsi. FineTune mengingat ini untuk setiap perangkat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva solo se il cursore del volume non funziona. FineTune lo ricorda per ciascun dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音量スライダーが機能しない場合にのみオンにします。 FineTune はこれをデバイスごとに記憶します。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ವಾಲ್ಯೂಮ್ ಸ್ಲೈಡರ್ ಕೆಲಸ ಮಾಡದಿದ್ದರೆ ಮಾತ್ರ ಆನ್ ಮಾಡಿ. ಪ್ರತಿ ಸಾಧನಕ್ಕೆ FineTune ಇದನ್ನು ನೆನಪಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "볼륨 슬라이더가 작동하지 않는 경우에만 켜십시오. FineTune은 각 장치에 대해 이를 기억합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hidupkan hanya jika peluncur kelantangan tidak berfungsi. FineTune mengingati ini untuk setiap peranti."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "വോളിയം സ്ലൈഡർ പ്രവർത്തിക്കുന്നില്ലെങ്കിൽ മാത്രം ഓണാക്കുക. ഓരോ ഉപകരണത്തിനും FineTune ഇത് ഓർമ്മിക്കുന്നു."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "व्हॉल्यूम स्लाइडर काम करत नसेल तरच चालू करा. FineTune हे प्रत्येक उपकरणासाठी लक्षात ठेवते."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Slå på bare hvis volumskyveknappen ikke fungerer. FineTune husker dette for hver enhet."
          }
        },
        "or-IN": {
