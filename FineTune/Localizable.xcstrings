    "Registers FineTune in the Accessibility list and opens System Settings.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 FineTune 加入辅助功能列表并打开系统设置。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "يقوم بتسجيل FineTune في قائمة إمكانية الوصول ويفتح إعدادات النظام."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রবেশযোগ্যতা তালিকায় FineTune নিবন্ধন করে এবং সিস্টেম সেটিংস খোলে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra FineTune a la llista d'accessibilitat i obre la configuració del sistema."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在輔助使用清單中註冊FineTune 並開啟系統設定。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrira FineTune na popisu pristupačnosti i otvara postavke sustava."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaregistruje FineTune do seznamu Usnadnění a otevře Nastavení systému."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrerer FineTune på tilgængelighedslisten og åbner Systemindstillinger."
          }
        },
        "nl-NL": {
          "stringUnit": {
