    "No correction active. Search or pick a favorite below.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未启用校正。请在下方搜索或选择收藏。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد تصحيح نشط. ابحث أو اختر المفضلة أدناه."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "কোনো সংশোধন সক্রিয় নেই। অনুসন্ধান করুন বা নীচে একটি প্রিয় চয়ন করুন."
          }
        },
