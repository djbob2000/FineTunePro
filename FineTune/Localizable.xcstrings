    "Media keys offline. Retry to reinstall the event tap.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "媒体键离线。重试以重新安装事件 tap。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "مفاتيح الوسائط غير متصلة بالإنترنت. أعد محاولة إعادة تثبيت صنبور الحدث."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "মিডিয়া কী অফলাইন। ইভেন্ট ট্যাপ পুনরায় ইনস্টল করার জন্য পুনরায় চেষ্টা করুন."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tecles multimèdia fora de línia. Torna a provar de tornar a instal·lar el toc de l'esdeveniment."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "媒體鍵離線。重試重新安裝事件水龍頭。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Medijske tipke izvan mreže. Pokušajte ponovo instalirati slavinu događaja."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediální klíče offline. Zkuste znovu nainstalovat kohoutek události."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Medietaster offline. Prøv igen at geninstallere hændelsestryk."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediatoetsen offline. Probeer opnieuw de gebeurtenistap opnieuw te installeren."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Media keys offline. Retry to reinstall the event tap."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Media keys offline. Retry to reinstall the event tap."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Media keys offline. Retry to reinstall the event tap."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Media keys offline. Retry to reinstall the event tap."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediaavaimet offline-tilassa. Yritä asentaa tapahtuma uudelleen napauttamalla."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Touches multimédia hors ligne. Réessayez de réinstaller le robinet d'événement."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Touches multimédia hors ligne. Réessayez de réinstaller le robinet d'événement."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Medientasten offline. Versuchen Sie erneut, den Event-Tap neu zu installieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πλήκτρα πολυμέσων εκτός σύνδεσης. Προσπαθήστε ξανά να εγκαταστήσετε ξανά το πάτημα συμβάντος."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "મીડિયા કી ઑફલાઇન. ઇવેન્ટ ટૅપને ફરીથી ઇન્સ્ટોલ કરવાનો ફરી પ્રયાસ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מקשי מדיה במצב לא מקוון. נסה שוב להתקין מחדש את הארוע הקש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मीडिया कुंजी ऑफ़लाइन। इवेंट टैप को पुनः स्थापित करने का पुनः प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Médiabillentyűk offline módban. Próbálja újra telepíteni az eseményt érintse meg."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunci media offline. Coba lagi untuk menginstal ulang tap acara."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tasti multimediali offline. Riprova a reinstallare il tocco dell'evento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メディア キーがオフラインです。イベントタップを再インストールしてみてください。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮಾಧ್ಯಮ ಕೀಗಳು ಆಫ್‌ಲೈನ್. ಈವೆಂಟ್ ಟ್ಯಾಪ್ ಅನ್ನು ಮರುಸ್ಥಾಪಿಸಲು ಮರುಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미디어 키가 오프라인입니다. 이벤트 탭을 다시 설치해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kekunci media di luar talian. Cuba semula untuk memasang semula ketik acara."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "മീഡിയ കീകൾ ഓഫ്‌ലൈനിൽ. ഇവൻ്റ് ടാപ്പ് വീണ്ടും ഇൻസ്റ്റാൾ ചെയ്യാൻ ശ്രമിക്കുക."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "मीडिया की ऑफलाइन. इव्हेंट टॅप पुन्हा स्थापित करण्यासाठी पुन्हा प्रयत्न करा."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Medietaster offline. Prøv på nytt for å installere hendelsestappen på nytt."
          }
        },
