    "Match macOS, or lock to Light or Dark": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跟随 macOS，或固定为浅色/深色"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بمطابقة macOS، أو قم بالقفل على Light أو Dark"
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "ম্যাচ macOS, অথবা আলো বা অন্ধকারে লক করুন"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Coincideix amb macOS o bloqueja a Clar o Fosc"
          }
        },
