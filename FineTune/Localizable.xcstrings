    "\"%@\" is back. %lld app(s) switched back.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”已重新连接。%lld 个 App 已切换回来。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "عاد \"%@\". تم تبديل التطبيق (التطبيقات) %lld مرة أخرى."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ফিরে এসেছে। %lld অ্যাপ(গুলি) ফিরে এসেছে৷"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ha tornat. Les aplicacions %lld s'han tornat a canviar."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”回來了。 %lld 應用程式切換回來。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" se vratio. %lld aplikacija(e) vraćena(e)."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" je zpět. Aplikace %lld přepnuty zpět."
