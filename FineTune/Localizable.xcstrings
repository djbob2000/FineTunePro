    "Enable in System Settings → Privacy & Security → Screen & System Audio Recording": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置 → 隐私与安全性 → 屏幕与系统音频录制中启用"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتمكين في إعدادات النظام ← الخصوصية والأمان ← تسجيل صوت الشاشة والنظام"
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্টেম সেটিংস → গোপনীয়তা এবং নিরাপত্তা → স্ক্রীন এবং সিস্টেম অডিও রেকর্ডিং এ সক্ষম করুন"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa a Configuració del sistema → Privadesa i seguretat → Pantalla i gravació d'àudio del sistema"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在系統設定 → 隱私和安全性 → 螢幕和系統音訊錄製中啟用"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Omogući u postavkama sustava → Privatnost i sigurnost → Snimanje zvuka zaslona i sustava"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Povolit v Nastavení systému → Soukromí a zabezpečení → Nahrávání zvuku obrazovky a systému"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver i Systemindstillinger → Privatliv og sikkerhed → Skærm- og systemlydoptagelse"
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Inschakelen in Systeeminstellingen → Privacy en beveiliging → Scherm- en systeemaudio-opname"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable in System Settings → Privacy & Security → Screen & System Audio Recording"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable in System Settings → Privacy & Security → Screen & System Audio Recording"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable in System Settings → Privacy & Security → Screen & System Audio Recording"
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable in System Settings → Privacy & Security → Screen & System Audio Recording"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ota käyttöön kohdassa Järjestelmäasetukset → Tietosuoja ja suojaus → Näyttö ja järjestelmä äänen tallennus"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Activer dans Paramètres système → Confidentialité et sécurité → Enregistrement audio de l'écran et du système"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Activer dans Paramètres système → Confidentialité et sécurité → Enregistrement audio de l'écran et du système"
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie die Option in den Systemeinstellungen → Datenschutz und Sicherheit → Bildschirm- und System-Audioaufzeichnung"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ενεργοποίηση στις Ρυθμίσεις συστήματος → Απόρρητο και ασφάλεια → Εγγραφή ήχου οθόνης και συστήματος"
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "સિસ્ટમ સેટિંગ્સ → ગોપનીયતા અને સુરક્ષા → સ્ક્રીન અને સિસ્ટમ ઓડિયો રેકોર્ડિંગમાં સક્ષમ કરો"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפעל בהגדרות מערכת ← פרטיות ואבטחה ← הקלטת אודיו מסך ומערכת"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम सेटिंग्स में सक्षम करें → गोपनीयता और सुरक्षा → स्क्रीन और सिस्टम ऑडियो रिकॉर्डिंग"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Engedélyezze a Rendszerbeállítások → Adatvédelem és biztonság → Képernyő és rendszer hangrögzítés menüpontjában"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan di Pengaturan Sistem → Privasi & Keamanan → Perekaman Audio Layar & Sistem"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita in Impostazioni di sistema → Privacy e sicurezza → Registrazione audio schermo e sistema"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "[システム設定] → [プライバシーとセキュリティ] → [画面とシステム音声録音] で有効にします"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಿಸ್ಟಂ ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ ಸಕ್ರಿಯಗೊಳಿಸಿ → ಗೌಪ್ಯತೆ ಮತ್ತು ಭದ್ರತೆ → ಸ್ಕ್ರೀನ್ ಮತ್ತು ಸಿಸ್ಟಂ ಆಡಿಯೋ ರೆಕಾರ್ಡಿಂಗ್"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 → 개인 정보 보호 및 보안 → 화면 및 시스템 오디오 녹음에서 활성화하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dayakan dalam Tetapan Sistem → Privasi & Keselamatan → Rakaman Audio Skrin & Sistem"
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "സിസ്റ്റം ക്രമീകരണങ്ങളിൽ പ്രവർത്തനക്ഷമമാക്കുക → സ്വകാര്യതയും സുരക്ഷയും → സ്‌ക്രീനും സിസ്റ്റം ഓഡിയോ റെക്കോർഡിംഗും"
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम सेटिंग्जमध्ये सक्षम करा → गोपनीयता आणि सुरक्षितता → स्क्रीन आणि सिस्टम ऑडिओ रेकॉर्डिंग"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver i Systeminnstillinger → Personvern og sikkerhet → Skjerm- og systemlydopptak"
          }
        },
