        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אין תיקון פעיל. חפש או בחר מועדף למטה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई सुधार सक्रिय नहीं। नीचे कोई पसंदीदा खोजें या चुनें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs aktív javítás. Keressen vagy válasszon egy kedvencet lent."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada koreksi yang aktif. Cari atau pilih favorit di bawah."
