        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "തിരുത്തലുകളൊന്നും സജീവമല്ല. താഴെ പ്രിയപ്പെട്ടത് തിരയുക അല്ലെങ്കിൽ തിരഞ്ഞെടുക്കുക."
          }
