    "Restart FineTune to apply the selected language.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重启 FineTune 以应用所选语言。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "أعد تشغيل FineTune لتطبيق اللغة المحددة."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "নির্বাচিত ভাষা প্রয়োগ করতে FineTune পুনরায় চালু করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinicieu FineTune per aplicar l'idioma seleccionat."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重新啟動FineTune 以套用所選語言。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponovno pokrenite FineTune za primjenu odabranog jezika."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Restartujte FineTune pro použití vybraného jazyka."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Genstart FineTune for at anvende det valgte sprog."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Start FineTune opnieuw om de geselecteerde taal toe te passen."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart FineTune to apply the selected language."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart FineTune to apply the selected language."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart FineTune to apply the selected language."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart FineTune to apply the selected language."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ota valittu kieli käyttöön käynnistämällä FineTune uudelleen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Redémarrez FineTune pour appliquer la langue sélectionnée."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Redémarrez FineTune pour appliquer la langue sélectionnée."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten Sie FineTune neu, um die ausgewählte Sprache anzuwenden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επανεκκινήστε το FineTune για να εφαρμόσετε την επιλεγμένη γλώσσα."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "પસંદ કરેલી ભાષા લાગુ કરવા FineTune પુનઃપ્રારંભ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפעל מחדש את FineTune כדי להחיל את השפה שנבחרה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चयनित भाषा लागू करने के लिए FineTune पुनः आरंभ करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Indítsa újra a FineTune programot a kiválasztott nyelv alkalmazásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulai ulang FineTune untuk menerapkan bahasa yang dipilih."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riavviare FineTune per applicare la lingua selezionata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune を再起動して、選択した言語を適用します。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಆಯ್ಕೆಮಾಡಿದ ಭಾಷೆಯನ್ನು ಅನ್ವಯಿಸಲು FineTune ಅನ್ನು ಮರುಪ್ರಾರಂಭಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 언어를 적용하려면 FineTune을 다시 시작하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulakan semula FineTune untuk menggunakan bahasa yang dipilih."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "തിരഞ്ഞെടുത്ത ഭാഷ പ്രയോഗിക്കാൻ FineTune പുനരാരംഭിക്കുക."
          }
        },
        "mr-IN": {
